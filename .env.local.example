# ──────────────────────────────────────────────────────────────────────────────
# ExamStitch — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — NEVER expose to the browser. Used by admin client only.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://examstitch.com
NEXT_PUBLIC_SITE_NAME=ExamStitch

# ── Analytics ────────────────────────────────────────────────────────────────
# Create a GA4 property at analytics.google.com → copy the Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up free at resend.com → API Keys → Create API Key
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ──────────────────────────────────────────────────────────────
# Create a project at console.cloud.google.com → Enable Drive API → Create API Key
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here

# ── Adobe PDF Embed API ───────────────────────────────────────────────────────
# developer.adobe.com → PDF Embed API → create credential; set Application Domain to your site (e.g. www.examstitch.com)
NEXT_PUBLIC_ADOBE_CLIENT_ID=
